<!DOCTYPE html>
<html lang="en">
  <head>
    <style>
      body {
        font-family: Georgia, "Times New Roman", Times, serif;
      }
    </style>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EJS SSR</title>
  </head>
  <body>
    <div>
      <h1>URL Shortner</h1>
      <!-- After successful POST request, check if in locals (which is backend containing the variables we store), urlId exists -->
      <% if (locals.urlId) { %>
        <p>Short URL Generated with unique ID: http://localhost:8080/urlShortner/<%= urlId %> </p>
      <% } %>
      <div>
        <form method="post" action="/urlShortner">
          <label>Enter your original URL</label>
          <!-- Value in 'name' property represents with what name value will be coming from front end -->
          <input
            type="text"
            name="url"
            placeholder="https://example.com"
          />
          <button type="submit">Generate</button>
        </form>
      </div>
    </div>

    <div>
        <% if (locals.urls) { %>
         <table>
            <thead>
                <th>Serial No.</th>
                <th>Short ID</th>
                <th>Redirect</th>
                <th>No. of clicks </th>
            </thead>
            <tbody>
                <% urls.forEach((url, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= url.shortUrlId  %> </td>
                        <td><%= url.redirectUrl %> </td>
                        <td><%= url.vistHistory.length %> </td>
                    </tr>
                <% }) %>
            </tbody>
         </table>
        <% } %>
    </div>
  </body>
</html>
